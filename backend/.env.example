# ─── Application ──────────────────────────────────────────
APP_NAME=PortfolioSaaS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

ADMIN_EMAIL=admin@example.com

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ─── Logging ──────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database (PostgreSQL) ────────────────────────────────
# Default host "postgres" matches the Docker Compose service name.
# Use "127.0.0.1" when running the backend outside Docker.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=portfolio_saas
DB_USERNAME=portfolio_saas
DB_PASSWORD=secret

# ─── Session ──────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Broadcasting & Reverb (WebSockets) ───────────────────
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="0.0.0.0"
REVERB_PORT=8080
REVERB_SCHEME=http

# ─── Filesystem ───────────────────────────────────────────
FILESYSTEM_DISK=local

# ─── Queue ────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ─── Cache ────────────────────────────────────────────────
CACHE_STORE=redis
# CACHE_PREFIX=

# ─── Redis ────────────────────────────────────────────────
# Default host "redis" matches the Docker Compose service name.
# Use "127.0.0.1" when running the backend outside Docker.
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail (Development — Mailpit) ─────────────────────────
# In production, replace with your actual SMTP provider (e.g., Mailgun, Postmark).
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Sanctum (API Auth) ──────────────────────────────────
# Comma-separated list of frontend domains for SPA stateful authentication.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000
SANCTUM_TOKEN_PREFIX=

# ─── OAuth (Laravel Socialite) ────────────────────────────
# Obtain these credentials from each provider's developer console.
# The redirect URI should be set to: http://localhost:8080/api/v1/auth/{provider}/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=

# ─── Documenso (Self-Hosted Document Signing) ─────────────
DOCUMENSO_API_URL=http://documenso:3000
DOCUMENSO_API_TOKEN=

# ─── Payment: OpenBCB (Bolivian Bank Transfer) ────────────
OPENBCB_API_URL=
OPENBCB_API_TOKEN=

# ─── Payment: PayPal ──────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true
PAYPAL_WEBHOOK_ID=

# ─── Payment: Binance Pay ─────────────────────────────────
BINANCE_PAY_API_KEY=
BINANCE_PAY_SECRET_KEY=

# ─── Chatbot — Groq ──────────────────────────────────────
GROQ_API_KEY=

# ─── Analytics — Umami ───────────────────────────────────
UMAMI_URL=http://umami:3000

# ─── Newsletter — Listmonk ───────────────────────────────
LISTMONK_URL=http://listmonk:3002

# ─── Error Tracking — GlitchTip ──────────────────────────
GLITCHTIP_DSN=

# ─── AWS (Optional — File Storage) ───────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Vite ─────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
