# ─── API ───────────────────────────────────────────
# Base URL for the Laravel backend API (versioned).
# Use the Docker service name ("backend") when running in containers,
# or "localhost" when running the frontend standalone.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ─── Reverb (WebSockets) ───────────────────────────
# These must match the REVERB_* values in backend/.env
NEXT_PUBLIC_REVERB_APP_KEY=
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=http

# ─── Reverb (Laravel Echo — client-side broadcasting) ──
# Used by Echo + Pusher JS for real-time streaming of chatbot AI responses.
# The VITE_ prefix is the convention Laravel Echo reads from the environment.
VITE_REVERB_APP_KEY=portfolio-reverb-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
